<?xml version="1.0"?>
<rdf:RDF xmlns="http://purl.org/nampi/owl/monastic-life#"
     xml:base="http://purl.org/nampi/owl/monastic-life"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:core="http://purl.org/nampi/owl/core#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#">
    <owl:Ontology rdf:about="http://purl.org/nampi/owl/monastic-life">
        <owl:versionIRI rdf:resource="http://purl.org/nampi/owl/monastic-life/0.4.0"/>
        <owl:imports rdf:resource="http://purl.org/nampi/owl/core/0.3.0"/>
    </owl:Ontology>
    


