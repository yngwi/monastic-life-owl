    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/nampi/owl/core#has_other_participant -->

    <owl:ObjectProperty rdf:about="http://purl.org/nampi/owl/core#has_other_participant"/>
    


    <!-- http://purl.org/nampi/owl/core#has_participant -->

    <owl:ObjectProperty rdf:about="http://purl.org/nampi/owl/core#has_participant"/>
    


    <!-- http://purl.org/nampi/owl/core#has_place -->

    <owl:ObjectProperty rdf:about="http://purl.org/nampi/owl/core#has_place"/>
    


    <!-- http://purl.org/nampi/owl/core#has_source -->

    <owl:ObjectProperty rdf:about="http://purl.org/nampi/owl/core#has_source"/>
    


    <!-- http://purl.org/nampi/owl/core#participates_in -->

    <owl:ObjectProperty rdf:about="http://purl.org/nampi/owl/core#participates_in"/>
    


    <!-- http://purl.org/nampi/owl/monastic-life#has_godparent -->

    <owl:ObjectProperty rdf:about="http://purl.org/nampi/owl/monastic-life#has_godparent">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/nampi/owl/core#has_other_participant"/>
        <rdfs:comment xml:lang="en">Signifies that an actor acts as godparent of the main person in the event (e.g. at baptism or confirmation).</rdfs:comment>
        <rdfs:comment xml:lang="de">Bedeutet, dass ein Akteur als Pate bzw. Patin der Hauptperson des Ereignisses auftritt (z. B. bei Taufe oder Firmung).</rdfs:comment>
        <rdfs:label xml:lang="en">has godparent</rdfs:label>
        <rdfs:label xml:lang="de">hat Paten</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/nampi/owl/monastic-life#is_godparent_in -->

    <owl:ObjectProperty rdf:about="http://purl.org/nampi/owl/monastic-life#is_godparent_in">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/nampi/owl/core#participates_in"/>
        <rdfs:comment xml:lang="en">Signifies that an actor acts as godparent of the main person in the event (e.g. at baptism or confirmation).</rdfs:comment>
        <rdfs:comment xml:lang="de">Bedeutet, dass ein Akteur als Pate bzw. Patin der Hauptperson des Ereignisses auftritt (z. B. bei Taufe oder Firmung).</rdfs:comment>
        <rdfs:label xml:lang="en">is godparent in</rdfs:label>
        <rdfs:label xml:lang="de">ist Pate in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/nampi/owl/core#has_text -->

    <owl:DatatypeProperty rdf:about="http://purl.org/nampi/owl/core#has_text"/>
    


